    "relink": "pnpm uninstall --global vazen && pnpm link --global",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@orpc/server": "catalog:orpc",
    "trpc-cli": "^0.14.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "tsdown": "^0.22.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.22.3"
  }
}
