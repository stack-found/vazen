{
  "name": "vazen",
  "version": "0.0.1",
  "private": false,
  "license": "MIT",
  "bin": {
    "vazen": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist .turbo",
    "dev": "tsdown -w",
