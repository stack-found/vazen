{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["src/index.{js,jsx,mjs}", "src/main.{js,jsx,mjs}"],
  "workspaces": {
    "packages": ["apps/*", "packages/*", "tooling/*"]
  },
  "ignorePatterns": ["oxfmt.config.ts"],
  "ignoreDependencies": ["babel-plugin-react-compiler", "postcss-load-config"]
}
