{
  "name": "vazen",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean && rimraf .fallow .turbo node_modules",
    "dev": "turbo dev",
    "docker:clean": "docker compose down -v",
    "docker:down": "docker compose down",
    "docker:up": "docker compose up -d",
    "fallow": "fallow",
    "fallow:dead": "fallow dead-code --format human",
    "fallow:dupes": "fallow dupes --format human",
    "fallow:health": "fallow health --format human",
    "fmt": "oxfmt",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "web:build": "turbo build -F web...",
    "web:dev": "turbo dev -F web..."
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/node": "catalog:",
    "fallow": "^2.62.0",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.47.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.8",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.2"
}
